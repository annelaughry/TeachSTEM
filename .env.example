# Copy to .env for local dev (loaded automatically via python-dotenv).
# In AWS these are set as ECS task definition env vars / secrets instead
# of a file -- see DEPLOYMENT.md.

# --- Django core ---
DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=False
# Comma-separated. In production: api.yourdomain.org
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (RDS Postgres in prod; omit DB_HOST to fall back to sqlite locally) ---
DB_HOST=
DB_PORT=5432
DB_NAME=lessons
DB_USER=lessons
DB_PASSWORD=
DB_SSLMODE=require

# --- CORS / CSRF (the deployed React app's origin) ---
CORS_ALLOWED_ORIGINS=https://app.yourdomain.org
CSRF_TRUSTED_ORIGINS=https://api.yourdomain.org

# --- S3 media storage (leave blank to use local disk in dev) ---
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
# Optional: CloudFront domain in front of the media bucket
AWS_S3_CUSTOM_DOMAIN=

# --- Whether to force HTTPS redirects (keep True in production) ---
DJANGO_SECURE_SSL_REDIRECT=True
